# ================================================================
#  Frontend — Environment Variables
#  Set these in your Vercel / Render / Netlify dashboard.
#  DO NOT commit .env.local or .env.production — they contain keys!
# ================================================================

# Your Supabase project URL (find in: Supabase → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/public key (safe to expose — it's a public key)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your deployed backend URL (Render service URL)
VITE_API_URL=https://your-backend.onrender.com
